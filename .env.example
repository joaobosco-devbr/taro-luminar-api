API_KEY=coloque_sua_api_key_aqui

# Mercado Pago
MP_ACCESS_TOKEN_TEST=coloque_seu_access_token_de_teste
PAYMENT_WEBHOOK_MAX_RETRIES=3
PAYMENT_WEBHOOK_RETRY_DELAY_MS=250

# Ambiente
APP_NAME=taro-luminar-api
NODE_ENV=development
ALLOWED_ORIGINS=

# Porta da aplicacao (opcional)
PORT=3000
JSON_BODY_LIMIT=16kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
WEBHOOK_RATE_LIMIT_WINDOW_MS=300000
WEBHOOK_RATE_LIMIT_MAX=30

# Banco SQLite (opcional)
DATABASE_FILE=src/storage/app.sqlite
